// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  passwordHash     String
  name             String
  role             String       // ADMIN, MANAGER, SALES, DESIGNER, PRODUCTION, ACCOUNTANT, DELIVERY
  status           String       @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  quotes           Quote[]
  approvedFiles    DesignFile[] @relation("FileApprover")
  sessions         Session[]
  createdCustomers Customer[]   @relation("CustomerCreator")
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // Băm SHA-256 của token
  expiresAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userAgent String?
  ipAddress String?
  revokedAt DateTime?
}

model Customer {
  id           String   @id @default(uuid())
  customerCode String   @unique // KH-000001, KH-000002...
  name         String
  phone        String   @unique
  zalo         String?
  email        String?
  address      String?
  customerType String   @default("RETAIL") // RETAIL, COMPANY, AGENCY, FNB, COSMETIC, PHARMA, OTHER
  source       String   @default("OTHER")  // FACEBOOK, ZALO, TIKTOK, GOOGLE, REFERRAL, WALK_IN, OTHER
  taxCode      String?
  companyName  String?
  note         String?
  tags         String?  // VIP, THAN_THIET, regular
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE
  debtBalance  Float    @default(0)
  createdById  String?
  createdBy    User?    @relation("CustomerCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  quotes       Quote[]
  orders       Order[]
}

model Quote {
  id           String      @id @default(uuid())
  quoteNumber  String      @unique
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  totalAmount  Float
  status       String      // DRAFT, SENT, APPROVED, REJECTED
  notes        String?
  createdById  String
  createdBy    User        @relation(fields: [createdById], references: [id])
  createdAt    DateTime    @default(now())
  items        QuoteItem[]
  orders       Order[]
}

model QuoteItem {
  id       String @id @default(uuid())
  quoteId  String
  quote    Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name     String // Tên sản phẩm, ví dụ: Hộp giấy Couche
  qty      Int    // Số lượng in
  size     String // Kích thước
  paper    String // Chất liệu giấy
  print    String // Quy cách in
  process  String // Quy cách gia công
  price    Float  // Đơn giá sản phẩm
}

model Order {
  id              String           @id @default(uuid())
  orderNumber     String           @unique
  quoteId         String?
  quote           Quote?           @relation(fields: [quoteId], references: [id])
  customerId      String
  customer        Customer         @relation(fields: [customerId], references: [id])
  status          String           // PENDING, DESIGNING, DESIGN_APPROVED, PRODUCING, COMPLETED, DELIVERED, CANCELLED
  deliveryDate    DateTime
  totalAmount     Float
  paidAmount      Float            @default(0)
  debtAmount      Float            @default(0)
  estimatedCost   Float            // Chi phí sản xuất dự toán
  estimatedProfit Float            // Lợi nhuận ước tính
  profitMargin    Float            // Tỷ suất lợi nhuận (%)
  notes           String?
  createdAt       DateTime         @default(now())
  items           OrderItem[]
  designFiles     DesignFile[]
  productionSteps ProductionStep[]
  payments        Payment[]
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name    String
  qty     Int
  size    String
  paper   String
  print   String
  process String
  price   Float
}

model DesignFile {
  id            String    @id @default(uuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fileName      String    // Tên file final
  fileUrl       String    // Đường dẫn file
  uploadedAt    DateTime  @default(now())
  approvedById  String?
  approvedBy    User?     @relation("FileApprover", fields: [approvedById], references: [id])
  approvedAt    DateTime?
}

model ProductionStep {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stepName   String   // IN_AN, BE_THANH_PHAM, DAN_GIAO, DONG_GOI
  status     String   // PENDING, PROCESSING, COMPLETED
  assignedTo String?
  updatedAt  DateTime @updatedAt
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount        Float
  paymentDate   DateTime @default(now())
  paymentMethod String   // CASH, TRANSFER
  notes         String?
}

model Material {
  id           String   @id @default(uuid())
  name         String   // Tên vật tư (Giấy Couche 300, Decal, Ghim...)
  type         String   // Phân loại: GIAY, NHU, MANG, MUC, PHU_LIEU
  qtyInStock   Float    @default(0) // Số lượng tồn kho
  unit         String   // Đơn vị tính: Tờ, Mét, Cuộn, Kg
  pricePerUnit Float    // Đơn giá nhập khẩu/vật tư
  updatedAt    DateTime @updatedAt
}

model PriceRule {
  id          String   @id @default(uuid())
  category    String   // Phân loại quy tắc: GIAY_IN, CONG_IN, GIA_CONG
  key         String   // Tên quy tắc (như: In offset Mitsubishi ca máy, Cán màng mờ...)
  value       Float    // Giá áp dụng định mức
  unit        String   // Đơn vị tính
  description String?  // Mô tả quy tắc
  updatedAt   DateTime @updatedAt
}
